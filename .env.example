# Copy this file to `.env` and fill in your own values.
# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.

# MapTiler API key for the map tile server (https://cloud.maptiler.com/account/keys/).
# Restrict the key by allowed origins / bundle id in the MapTiler dashboard,
# since it ships in the client bundle.
EXPO_PUBLIC_MAPTILER_KEY=

# Google AdMob ad-unit IDs (https://apps.admob.com/). One per format/platform.
# These are not secret, but live here so test/prod can differ and stay out of source.
# When empty, or in development builds, the app falls back to Google's test ad units.
# The AdMob *App* IDs (ca-app-pub-...~...) live in app.json under the
# react-native-google-mobile-ads plugin, since they are baked in at build time.
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_IOS=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS=
