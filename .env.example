# Copy this file to `.env` and fill in your own values.
# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.

# MapTiler API key for the map tile server (https://cloud.maptiler.com/account/keys/).
# Restrict the key by allowed origins / bundle id in the MapTiler dashboard,
# since it ships in the client bundle.
EXPO_PUBLIC_MAPTILER_KEY=
